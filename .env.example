# nepalkings server environment variables
# Copy to `.env` (which is gitignored) and fill in real values for
# local development, or set these in your hosting environment in
# production. NEVER commit a populated `.env` file.

# ── Server / public URLs ──────────────────────────────────────────
SERVER_URL=http://localhost:5000
SERVER_BASE_URL=http://localhost:5000

# ── Environment switch ────────────────────────────────────────────
# Anything other than dev/development/local/test/empty triggers the
# production safety guards in server.py (requires SECRET_KEY, blocks
# DROP_TABLES_ON_STARTUP=True).
FLASK_ENV=development

# ── Security / auth ───────────────────────────────────────────────
# REQUIRED in production. A 64-char hex string is recommended:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=
TOKEN_EXPIRY_SECONDS=86400

# Comma-separated list of allowed CORS origins, or '*' to allow any.
# Default is locked down to localhost only.
# For GitHub Pages in production, this is typically:
#   CORS_ORIGINS=https://YOURNAME.github.io
CORS_ORIGINS=http://localhost,http://localhost:5000,http://127.0.0.1,http://127.0.0.1:5000

# Flask-Limiter rate limits.
RATE_LIMIT_DEFAULT=600 per minute
RATE_LIMIT_LOGIN=10 per minute
RATE_LIMIT_REGISTER=5 per minute

# ── Database ──────────────────────────────────────────────────────
DB_URL=sqlite:///test.db
# DESTRUCTIVE. Default is False. Only set True for local schema iteration.
DROP_TABLES_ON_STARTUP=False

# ── Email verification (optional) ─────────────────────────────────
EMAIL_VERIFICATION_ENABLED=False
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
# REQUIRED if EMAIL_VERIFICATION_ENABLED=True. Treat as a secret.
SMTP_PASSWORD=
SMTP_FROM=noreply@nepalkings.local

# ── AI opponent ───────────────────────────────────────────────────
# Treat as a secret. Leave blank to disable LLM-driven AI moves.
OPENAI_API_KEY=
AI_PROVIDER=openai
AI_MODEL=gpt-4.1-mini
AI_ENABLED=True
AI_CHAT_ENABLED=True

# ── Debug logging (do not enable in production) ───────────────────
DEBUG_ENABLED=False
DEBUG_LOG_TO_FILE=False
DEBUG_LOG_PATH=/tmp/nepalkings_debug.log
