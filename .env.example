# nepalkings server environment variables
# Copy to `.env` (which is gitignored) and fill in real values for
# local development, or set these in your hosting environment in
# production. NEVER commit a populated `.env` file.

# ── Server / public URLs ──────────────────────────────────────────
SERVER_URL=http://localhost:5000
SERVER_BASE_URL=http://localhost:5000

# ── Environment switch ────────────────────────────────────────────
# Anything other than dev/development/local/test/empty triggers the
# production safety guards in server.py (requires SECRET_KEY, blocks
# DROP_TABLES_ON_STARTUP=True).
FLASK_ENV=development
APP_ENVIRONMENT=development

# ── Security / auth ───────────────────────────────────────────────
# REQUIRED in production. A 64-char hex string is recommended:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=
TOKEN_EXPIRY_SECONDS=86400

# Comma-separated list of allowed CORS origins, or '*' to allow any.
# Default is locked down to localhost only.
# For GitHub Pages in production, this is typically:
#   CORS_ORIGINS=https://YOURNAME.github.io
CORS_ORIGINS=http://localhost,http://localhost:5000,http://127.0.0.1,http://127.0.0.1:5000

# Maximum request body size in bytes (default 256 KB). All API payloads
# are small JSON/form bodies; oversized requests get a JSON 413.
MAX_CONTENT_LENGTH=262144

# Flask-Limiter rate limits.
# NOTE: with the default in-memory storage (RATELIMIT_STORAGE_URI=memory://)
# each worker process keeps its own counters, so the effective limit is
# roughly limit × worker_count. Point RATELIMIT_STORAGE_URI at a shared
# backend (e.g. redis://localhost:6379) for exact cross-worker limits.
RATELIMIT_STORAGE_URI=memory://
RATE_LIMIT_DEFAULT=600 per minute
RATE_LIMIT_LOGIN=10 per minute
RATE_LIMIT_REGISTER=5 per minute
RATE_LIMIT_LOOKUP=60 per minute

# Bump these when Terms or Privacy wording materially changes.
LEGAL_TERMS_VERSION=2026-06-12
LEGAL_PRIVACY_VERSION=2026-06-12

# ── Database ──────────────────────────────────────────────────────
DB_URL=sqlite:///test.db
# Public production must use PostgreSQL. PythonAnywhere supplies the host and
# port on its Databases tab:
# DB_URL=postgresql+psycopg://APP_USER:URL_ENCODED_PASSWORD@HOST:PORT/DB_NAME
# DESTRUCTIVE. Default is False. Only set True for local schema iteration.
DROP_TABLES_ON_STARTUP=False
ALLOW_PRODUCTION_SQLITE=False
DB_POOL_SIZE=2
DB_MAX_OVERFLOW=1
DB_POOL_TIMEOUT_SECONDS=10
DB_POOL_RECYCLE_SECONDS=280

# Production deploys run database preparation explicitly before WSGI reload.
STARTUP_MAINTENANCE_ENABLED=True
BACKGROUND_SERVICES_ENABLED=True
MAINTENANCE_MODE=False
RESPONSE_COMPRESSION_ENABLED=True
RESPONSE_COMPRESSION_MIN_BYTES=1024
MAINTENANCE_MESSAGE=Nepal Kings is temporarily unavailable for maintenance.
MAINTENANCE_RETRY_AFTER_SECONDS=300

# ── Public release metadata ───────────────────────────────────────
RELEASE_SHA=unknown
API_VERSION=1
MIN_CLIENT_VERSION=0.0.0

# ── Email verification (optional) ─────────────────────────────────
EMAIL_VERIFICATION_ENABLED=False
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
# REQUIRED if EMAIL_VERIFICATION_ENABLED=True. Treat as a secret.
SMTP_PASSWORD=
SMTP_FROM=noreply@nepalkings.local

# ── Gameplay notification emails ──────────────────────────────────
# "It's your turn" / "you've been challenged" / "game finished" emails for
# offline players (async play). Uses the SMTP settings above; without
# SMTP_HOST the emails are logged instead of sent. Players can opt out
# in-game or via the unsubscribe link included in every email.
NOTIFY_EMAILS_ENABLED=True
# Public URL of the playable web client, linked in notification emails.
WEB_CLIENT_URL=

# ── First-party analytics ─────────────────────────────────────────
# Append-only event log in the app database (no third parties, no IPs).
# Read it with: python scripts/funnel_report.py
ANALYTICS_ENABLED=True

# ── AI opponent (rule-based, no external API) ─────────────────────
AI_ENABLED=True

# ── Debug logging (do not enable in production) ───────────────────
DEBUG_ENABLED=False
DEBUG_LOG_TO_FILE=False
DEBUG_LOG_PATH=/tmp/nepalkings_debug.log
