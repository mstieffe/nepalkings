# Copy to /home/USERNAME/.config/nepalkings/staging.env and chmod 600.
# Staging must use a separate database and a separate signing key.

APP_ENVIRONMENT=staging
SECRET_KEY=CHANGE_ME_DIFFERENT_64_CHAR_RANDOM_HEX
DB_URL=postgresql+psycopg://nepalkings_staging:CHANGE_ME_URL_ENCODED_PASSWORD@CHANGE_ME_POSTGRES_HOST:CHANGE_ME_PORT/nepalkings_staging

SERVER_URL=https://CHANGE_ME_STAGING_API_DOMAIN
SERVER_BASE_URL=https://CHANGE_ME_STAGING_API_DOMAIN
CORS_ORIGINS=https://mstieffe.github.io

DROP_TABLES_ON_STARTUP=False
ALLOW_PRODUCTION_SQLITE=False
STARTUP_MAINTENANCE_ENABLED=False
BACKGROUND_SERVICES_ENABLED=False
MAINTENANCE_MODE=False
MAINTENANCE_RETRY_AFTER_SECONDS=300
REGISTRATION_ENABLED=True
CHAT_ENABLED=True
NEW_GAMES_ENABLED=True
CONQUER_ENABLED=True
AI_JOBS_ENABLED=True
CORS_PREFLIGHT_MAX_AGE_SECONDS=600
DB_POOL_SIZE=1
DB_MAX_OVERFLOW=1
DB_POOL_TIMEOUT_SECONDS=10
DB_POOL_RECYCLE_SECONDS=280
RATE_LIMIT_CHAT=12 per minute
RATE_LIMIT_REPORT=5 per hour

RELEASE_SHA=CHANGE_ME_COMMIT_SHA
API_VERSION=1
MIN_CLIENT_VERSION=0.0.0
LEGAL_TERMS_VERSION=2026-07-20
LEGAL_PRIVACY_VERSION=2026-07-20

# Web workers never spawn AI threads. The dedicated always-on task overrides
# this to True on its command line.
AI_ENABLED=False
BACKGROUND_WORKER_POLL_SECONDS=2
DEBUG_ENABLED=False
