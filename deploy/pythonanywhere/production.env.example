# Copy to /home/USERNAME/.config/nepalkings/production.env and chmod 600.
# Replace every CHANGE_ME value. Never commit the populated file.

APP_ENVIRONMENT=production
SECRET_KEY=CHANGE_ME_64_CHAR_RANDOM_HEX
DB_URL=postgresql+psycopg://nepalkings_prod:CHANGE_ME_URL_ENCODED_PASSWORD@CHANGE_ME_POSTGRES_HOST:CHANGE_ME_PORT/nepalkings_prod

SERVER_URL=https://CHANGE_ME_PRODUCTION_API_DOMAIN
SERVER_BASE_URL=https://CHANGE_ME_PRODUCTION_API_DOMAIN
CORS_ORIGINS=https://mstieffe.github.io

DROP_TABLES_ON_STARTUP=False
ALLOW_PRODUCTION_SQLITE=False
STARTUP_MAINTENANCE_ENABLED=False
BACKGROUND_SERVICES_ENABLED=False
MAINTENANCE_MODE=False
MAINTENANCE_RETRY_AFTER_SECONDS=300
DB_POOL_SIZE=2
DB_MAX_OVERFLOW=1
DB_POOL_TIMEOUT_SECONDS=10
DB_POOL_RECYCLE_SECONDS=280

RELEASE_SHA=CHANGE_ME_COMMIT_SHA
API_VERSION=1
MIN_CLIENT_VERSION=0.0.0

AI_ENABLED=True
DEBUG_ENABLED=False
